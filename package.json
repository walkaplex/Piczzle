{
  "name": "piczzle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/prepare-capacitor.mjs",
    "verify": "npm run verify:sharing && npm run verify:native",
    "verify:sharing": "node scripts/verify-sharing-config.mjs",
    "verify:native": "npm run build && node scripts/verify-native-package.mjs",
    "verify:public": "node scripts/verify-public-site.mjs",
    "verify:play": "node scripts/verify-play-readiness.mjs",
    "android:doctor": "node scripts/android-doctor.mjs",
    "android:debug": "node scripts/build-android-debug.mjs",
    "android:release": "node scripts/build-android-release.mjs",
    "android:run": "node scripts/run-android-debug.mjs",
    "android:package": "node scripts/package-android-debug.mjs",
    "android:screenshot": "node scripts/android-screenshot.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:add:ios": "npm run build && npx cap add ios",
    "cap:add:android": "npm run build && npx cap add android",
    "cap:open:ios": "npm run build && npx cap open ios",
    "cap:open:android": "npm run build && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0"
  }
}
